# === Language Immersion Roleplayer ===
# Copy this file to .env and fill in your API keys.

# --- Mode ---
# Set to "true" to use mock/stub responses (no API keys needed)
MOCK_MODE=false

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- OpenAI (Whisper STT) ---
# Only needed if WHISPER_MODE=api (not needed for local Whisper)
OPENAI_API_KEY=sk-xxxxx

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=xxxxx

# --- Whisper mode ---
# "api" = use OpenAI Whisper API, "local" = run Whisper on local GPU
WHISPER_MODE=api

# --- Database (PostgreSQL via Supabase or local) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/roleplayer
# If using Supabase:
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=xxxxx

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- Audio ---
# Max session duration in seconds (default 30 minutes)
MAX_SESSION_DURATION=1800
# Silence timeout in ms before ending session
SILENCE_TIMEOUT_MS=60000
